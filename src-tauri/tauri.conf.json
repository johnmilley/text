{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pt",
  "version": "0.2.10",
  "identifier": "com.johnathan.pt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "pt",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 320,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "pt.desktop.template",
        "files": {
          "/usr/share/icons/hicolor/32x32/apps/com.johnathan.pt.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/com.johnathan.pt.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256@2/apps/com.johnathan.pt.png": "icons/128x128@2x.png"
        }
      },
      "rpm": {
        "desktopTemplate": "pt.desktop.template",
        "files": {
          "/usr/share/icons/hicolor/32x32/apps/com.johnathan.pt.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/128x128/apps/com.johnathan.pt.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256@2/apps/com.johnathan.pt.png": "icons/128x128@2x.png"
        }
      }
    }
  }
}
